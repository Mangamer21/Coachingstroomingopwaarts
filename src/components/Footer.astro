---
const year = new Date().getFullYear();
---

<footer>
	<div class="wave-top">
		<svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#03045e"/>
		</svg>
	</div>

	<div class="footer-body">
		<div class="footer-grid">
			<!-- Brand column -->
			<div class="footer-col brand-col">
				<img
					src="https://github.com/user-attachments/assets/22ef011f-75f5-472e-b58f-6f6fb45bf7a6"
					alt="Coaching Stroomingopwaarts logo"
					class="footer-logo"
					width="60"
					height="60"
				/>
				<p class="footer-tagline">Vooruitgang in elke Slag</p>
				<p class="footer-name">Gian Luca Bosmans</p>
				<p class="footer-sub">Gediplomeerd zwemleerkracht</p>
			</div>

			<!-- Nav column -->
			<div class="footer-col">
				<h4>Navigatie</h4>
				<ul>
					<li><a href="/">Home</a></li>
					<li><a href="/diensten">Diensten</a></li>
					<li><a href="/over-mij">Over mij</a></li>
					<li><a href="/contact">Contact</a></li>
				</ul>
			</div>

			<!-- Diensten column -->
			<div class="footer-col">
				<h4>Diensten</h4>
				<ul>
					<li><a href="/diensten#zwemles-kinderen">Zwemles voor kinderen</a></li>
					<li><a href="/diensten#zwemles-volwassenen">Zwemles voor volwassenen</a></li>
					<li><a href="/diensten#bijles">Zwembijles</a></li>
					<li><a href="/diensten#groepsles">Groepsles</a></li>
				</ul>
			</div>

			<!-- Contact column -->
			<div class="footer-col">
				<h4>Contact</h4>
				<ul class="contact-list">
					<li>
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
						<a href="mailto:coachingstroomopwaarts@gmail.com">coachingstroomopwaarts@gmail.com</a>
					</li>
					<li>
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.3h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8a16 16 0 0 0 5.95 5.95l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.9 16h.02z"/></svg>
						<a href="tel:+320478410496">+32 (0)478410496</a>
					</li>
					<li>
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
						<span>België</span>
					</li>
				</ul>
			</div>
		</div>

		<div class="footer-bottom">
			<p>&copy; {year} Gian Luca Bosmans – Coaching Stroomingopwaarts. Alle rechten voorbehouden.</p>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: 0;
	}
	.wave-top {
		display: block;
		line-height: 0;
		overflow: hidden;
	}
	.wave-top svg {
		display: block;
		width: 100%;
	}
	.footer-body {
		background: var(--ocean-deep);
		color: rgba(255,255,255,0.8);
		padding: 3rem 1.5rem 2rem;
	}
	.footer-grid {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1.4fr 1fr 1fr 1fr;
		gap: 2.5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid rgba(255,255,255,0.1);
	}
	.footer-col h4 {
		color: var(--white);
		font-family: "Nunito", sans-serif;
		font-size: 0.85rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 1rem;
	}
	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.footer-col a {
		color: rgba(255,255,255,0.7);
		text-decoration: none;
		font-size: 0.95rem;
		transition: color 0.2s;
	}
	.footer-col a:hover {
		color: var(--aqua);
	}

	/* Brand column */
	.brand-col {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.footer-logo {
		width: 56px;
		height: 56px;
		object-fit: contain;
		border-radius: 50%;
		border: 2px solid rgba(144,224,239,0.4);
		margin-bottom: 0.25rem;
	}
	.footer-tagline {
		color: rgba(255,255,255,0.65);
		font-size: 0.95rem;
		line-height: 1.5;
		margin: 0;
	}
	.footer-name {
		color: var(--white);
		font-weight: 800;
		font-size: 1rem;
		margin: 0.25rem 0 0;
	}
	.footer-sub {
		color: var(--aqua);
		font-size: 0.85rem;
		margin: 0;
	}

	/* Contact list with icons */
	.contact-list li {
		display: flex;
		align-items: flex-start;
		gap: 0.6rem;
	}
	.contact-list svg {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		margin-top: 0.25rem;
		color: var(--aqua);
	}

	/* Bottom bar */
	.footer-bottom {
		max-width: 1200px;
		margin: 0 auto;
		padding-top: 1.5rem;
		text-align: center;
	}
	.footer-bottom p {
		font-size: 0.85rem;
		color: rgba(255,255,255,0.45);
		margin: 0;
	}

	@media (max-width: 900px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (max-width: 540px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
