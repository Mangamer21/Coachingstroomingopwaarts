---
import { SITE_TITLE } from '../consts';
---

<header id="site-header">
	<div class="header-inner">
		<a href="/" class="logo-link" aria-label="Home">
			<img
				src="https://github.com/user-attachments/assets/22ef011f-75f5-472e-b58f-6f6fb45bf7a6"
				alt="Coaching Stroomingopwaarts logo"
				class="logo-img"
				width="52"
				height="52"
			/>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>

		<button class="menu-toggle" id="menu-toggle" aria-label="Menu openen" aria-expanded="false" aria-controls="nav-menu">
			<span></span><span></span><span></span>
		</button>

		<nav id="nav-menu" role="navigation" aria-label="Hoofdnavigatie">
			<ul>
				<li><a href="/">Home</a></li>
				<li><a href="/diensten">Diensten</a></li>
				<li><a href="/over-mij">Over mij</a></li>
				<li><a href="/contact" class="nav-cta">Contact</a></li>
			</ul>
		</nav>
	</div>
</header>

<script>
	const toggle = document.getElementById('menu-toggle');
	const nav    = document.getElementById('nav-menu');
	const header = document.getElementById('site-header');

	// Mobile menu toggle
	toggle?.addEventListener('click', () => {
		const open = nav?.classList.toggle('open');
		toggle.setAttribute('aria-expanded', String(open));
	});

	// Sticky header with scroll shadow
	window.addEventListener('scroll', () => {
		header?.classList.toggle('scrolled', window.scrollY > 20);
	});

	// Close menu on nav link click
	nav?.querySelectorAll('a').forEach(link => {
		link.addEventListener('click', () => {
			nav.classList.remove('open');
			toggle?.setAttribute('aria-expanded', 'false');
		});
	});

	// Active link highlighting
	const path = window.location.pathname;
	nav?.querySelectorAll('a').forEach(link => {
		const href = link.getAttribute('href');
		if (href === path || (href !== '/' && path.startsWith(href ?? ''))) {
			link.classList.add('active');
		}
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: rgba(255,255,255,0.97);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid rgba(144,224,239,0.3);
		transition: box-shadow 0.3s ease;
	}
	header.scrolled {
		box-shadow: 0 2px 24px rgba(0,119,182,0.12);
	}

	.header-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 72px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	/* Logo */
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		color: var(--ocean-deep);
		flex-shrink: 0;
	}
	.logo-img {
		width: 46px;
		height: 46px;
		object-fit: contain;
		border-radius: 50%;
		border: 2px solid var(--foam);
	}
	.logo-text {
		font-family: "Playfair Display", serif;
		font-weight: 700;
		font-size: 1.1rem;
		color: var(--ocean-deep);
		line-height: 1.2;
	}

	/* Nav */
	nav ul {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	nav a {
		display: inline-block;
		padding: 0.5em 1em;
		border-radius: 50px;
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--text-mid);
		text-decoration: none;
		transition: background 0.2s, color 0.2s;
	}
	nav a:hover,
	nav a.active {
		background: var(--mist);
		color: var(--ocean);
	}
	nav a.nav-cta {
		background: linear-gradient(135deg, var(--ocean-mid), var(--sky));
		color: var(--white) !important;
		padding: 0.5em 1.4em;
		box-shadow: 0 3px 14px rgba(0,180,216,0.35);
	}
	nav a.nav-cta:hover {
		background: linear-gradient(135deg, var(--ocean), var(--ocean-mid));
		transform: translateY(-1px);
	}

	/* Mobile hamburger */
	.menu-toggle {
		display: none;
		flex-direction: column;
		justify-content: space-between;
		width: 28px;
		height: 20px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
	}
	.menu-toggle span {
		display: block;
		height: 2.5px;
		border-radius: 2px;
		background: var(--ocean);
		transition: all 0.25s ease;
	}

	@media (max-width: 768px) {
		.menu-toggle {
			display: flex;
		}
		nav {
			position: absolute;
			top: 72px;
			left: 0;
			right: 0;
			background: var(--white);
			border-bottom: 1px solid var(--mist);
			padding: 1rem 1.5rem 1.5rem;
			display: none;
			box-shadow: 0 8px 24px rgba(0,119,182,0.12);
		}
		nav.open {
			display: block;
		}
		nav ul {
			flex-direction: column;
			align-items: stretch;
			gap: 0.5rem;
		}
		nav a {
			padding: 0.75em 1.2em;
			border-radius: var(--radius-sm);
			font-size: 1rem;
		}
	}
</style>
