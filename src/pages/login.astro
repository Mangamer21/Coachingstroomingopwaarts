---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="nl">
	<head>
		<BaseHead
			title={`Login – ${SITE_TITLE}`}
			description="Beheerdersinlog voor Coaching Stroomingopwaarts"
		/>
	</head>
	<body class="login-body">

		<!-- Animated bubble background -->
		<div class="login-bg" aria-hidden="true">
			<div class="bubble b1"></div>
			<div class="bubble b2"></div>
			<div class="bubble b3"></div>
			<div class="bubble b4"></div>
			<div class="bubble b5"></div>
			<div class="bubble b6"></div>
			<div class="ripple r1"></div>
			<div class="ripple r2"></div>
		</div>

		<main class="login-wrapper">
			<!-- Dev banner -->
			<div class="dev-banner">
				<span class="dev-dot"></span>
				<span>Website in ontwikkeling &mdash; beperkte toegang</span>
			</div>

			<div class="login-card">
				<!-- Logo / branding -->
				<div class="login-logo">
					<div class="logo-icon">
						<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
							<circle cx="24" cy="24" r="22" fill="url(#grad)" />
							<path d="M10 30 Q16 22 24 28 Q32 34 38 26" stroke="white" stroke-width="3" stroke-linecap="round" fill="none"/>
							<path d="M10 22 Q16 14 24 20 Q32 26 38 18" stroke="rgba(255,255,255,0.55)" stroke-width="2" stroke-linecap="round" fill="none"/>
							<defs>
								<linearGradient id="grad" x1="0" y1="0" x2="48" y2="48" gradientUnits="userSpaceOnUse">
									<stop stop-color="#0077b6"/>
									<stop offset="1" stop-color="#00b4d8"/>
								</linearGradient>
							</defs>
						</svg>
					</div>
					<h1 class="login-title">Coaching<br/><em>Stroomingopwaarts</em></h1>
					<p class="login-subtitle">Beheerdersinlog</p>
				</div>

				<!-- Form -->
				<form class="login-form" id="loginForm">
					<div class="field-group">
						<label for="username">Gebruikersnaam</label>
						<div class="input-wrap">
							<svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
							</svg>
							<input
								type="text"
								id="username"
								name="username"
								autocomplete="username"
								placeholder="Voer gebruikersnaam in"
								required
							/>
						</div>
					</div>

					<div class="field-group">
						<label for="password">Wachtwoord</label>
						<div class="input-wrap">
							<svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
							</svg>
							<input
								type="password"
								id="password"
								name="password"
								autocomplete="current-password"
								placeholder="Voer wachtwoord in"
								required
							/>
							<button type="button" class="toggle-pw" aria-label="Wachtwoord tonen/verbergen" id="togglePw">
								<svg id="eyeIcon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
									<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
								</svg>
							</button>
						</div>
					</div>

					<div class="error-msg" id="errorMsg" role="alert" aria-live="polite"></div>

					<button type="submit" class="btn-login" id="submitBtn">
						<span class="btn-text">Inloggen</span>
						<span class="btn-spinner" aria-hidden="true"></span>
					</button>
				</form>

				<p class="login-note">
					🔒&nbsp;Beveiligde toegang &mdash; alleen voor beheerders
				</p>
			</div>
		</main>

	</body>
</html>

<script>
	// NOTE: This is a development-only gate. Credentials are intentionally
	// stored client-side because there is no sensitive data to protect at
	// this stage. Replace with server-side auth before going to production.

	// If already logged in this session, skip the login page
	if (sessionStorage.getItem('dev_auth') === '1') {
		window.location.replace('/');
	}

	const form     = document.getElementById('loginForm')   as HTMLFormElement;
	const errMsg   = document.getElementById('errorMsg')    as HTMLElement;
	const btn      = document.getElementById('submitBtn')   as HTMLButtonElement;
	const togglePw = document.getElementById('togglePw')   as HTMLButtonElement;
	const pwField  = document.getElementById('password')   as HTMLInputElement;

	// Toggle password visibility
	togglePw.addEventListener('click', () => {
		const show = pwField.type === 'password';
		pwField.type = show ? 'text' : 'password';
		togglePw.setAttribute('aria-pressed', String(show));
	});

	// Form submit
	form.addEventListener('submit', async (e) => {
		e.preventDefault();
		errMsg.textContent = '';
		btn.classList.add('loading');
		btn.disabled = true;

		const username = (document.getElementById('username') as HTMLInputElement).value.trim();
		const password = pwField.value;

		if (username === 'Admin' && password === 'Admin1234') {
			sessionStorage.setItem('dev_auth', '1');
			btn.classList.remove('loading');
			btn.classList.add('success');
			(btn.querySelector('.btn-text') as HTMLElement).textContent = '✓ Ingelogd!';
			await new Promise(r => setTimeout(r, 600));
			window.location.replace('/');
		} else {
			btn.classList.remove('loading');
			btn.disabled = false;
			errMsg.textContent = '❌ Ongeldige gebruikersnaam of wachtwoord.';
			// Shake animation on the card
			const card = document.querySelector('.login-card') as HTMLElement;
			card.classList.add('shake');
			card.addEventListener('animationend', () => card.classList.remove('shake'), { once: true });
		}
	});
</script>

<style>
/* ──────────────────────────────────────────────
   Login page – full page, no shared layout
   Uses brand variables from global.css
   ────────────────────────────────────────────── */

.login-body {
	margin: 0;
	min-height: 100vh;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	background: linear-gradient(135deg, var(--ocean-deep) 0%, var(--ocean) 55%, var(--sky) 100%);
	font-family: 'Nunito', 'Atkinson', sans-serif;
	overflow: hidden;
	position: relative;
}

/* ── Animated bubble background ── */
.login-bg {
	position: fixed;
	inset: 0;
	pointer-events: none;
	z-index: 0;
}

.bubble {
	position: absolute;
	border-radius: 50%;
	background: rgba(255, 255, 255, 0.07);
	animation: floatUp linear infinite;
}
.bubble.b1 { width: 90px;  height: 90px;  left: 8%;   bottom: -100px; animation-duration: 12s; animation-delay: 0s;   }
.bubble.b2 { width: 55px;  height: 55px;  left: 22%;  bottom: -100px; animation-duration: 9s;  animation-delay: 2s;   }
.bubble.b3 { width: 130px; height: 130px; left: 45%;  bottom: -100px; animation-duration: 15s; animation-delay: 1s;   }
.bubble.b4 { width: 70px;  height: 70px;  left: 65%;  bottom: -100px; animation-duration: 11s; animation-delay: 3.5s; }
.bubble.b5 { width: 40px;  height: 40px;  left: 80%;  bottom: -100px; animation-duration: 8s;  animation-delay: 0.8s; }
.bubble.b6 { width: 100px; height: 100px; left: 92%;  bottom: -100px; animation-duration: 13s; animation-delay: 5s;   }

.ripple {
	position: absolute;
	border-radius: 50%;
	border: 2px solid rgba(255, 255, 255, 0.12);
	animation: rippleOut ease-out infinite;
}
.ripple.r1 { width: 300px; height: 300px; left: -80px;  top: 60%;  animation-duration: 6s;  animation-delay: 0s; }
.ripple.r2 { width: 220px; height: 220px; right: -50px; top: 15%;  animation-duration: 5s;  animation-delay: 2s; }

@keyframes floatUp {
	0%   { transform: translateY(0)   scale(1);   opacity: 0.7; }
	50%  { transform: translateY(-50vh) scale(1.1); opacity: 0.4; }
	100% { transform: translateY(-110vh) scale(0.9); opacity: 0; }
}
@keyframes rippleOut {
	0%   { transform: scale(0.6); opacity: 0.6; }
	100% { transform: scale(2.2); opacity: 0; }
}

/* ── Dev banner ── */
.dev-banner {
	position: relative;
	z-index: 2;
	display: inline-flex;
	align-items: center;
	gap: 8px;
	background: rgba(249, 199, 79, 0.18);
	border: 1px solid rgba(249, 199, 79, 0.45);
	color: var(--gold);
	font-size: 0.78rem;
	font-weight: 700;
	letter-spacing: 0.04em;
	text-transform: uppercase;
	padding: 6px 16px;
	border-radius: 50px;
	margin-bottom: 20px;
	backdrop-filter: blur(8px);
}
.dev-dot {
	width: 8px;
	height: 8px;
	border-radius: 50%;
	background: var(--gold);
	animation: pulse 1.6s ease-in-out infinite;
}
@keyframes pulse {
	0%, 100% { opacity: 1;   transform: scale(1);   }
	50%       { opacity: 0.4; transform: scale(0.7); }
}

/* ── Card ── */
.login-wrapper {
	position: relative;
	z-index: 2;
	display: flex;
	flex-direction: column;
	align-items: center;
	width: 100%;
	padding: 24px 16px;
}

.login-card {
	background: rgba(255, 255, 255, 0.97);
	border-radius: var(--radius-lg);
	box-shadow: 0 24px 80px rgba(3, 4, 94, 0.35), 0 2px 8px rgba(0,119,182,0.15);
	padding: 44px 40px 36px;
	width: 100%;
	max-width: 420px;
	animation: cardIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}
@keyframes cardIn {
	from { opacity: 0; transform: translateY(40px) scale(0.96); }
	to   { opacity: 1; transform: translateY(0)    scale(1);    }
}

.login-card.shake {
	animation: shake 0.45s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
}
@keyframes shake {
	10%, 90%  { transform: translateX(-4px); }
	20%, 80%  { transform: translateX( 6px); }
	30%, 50%, 70% { transform: translateX(-6px); }
	40%, 60%  { transform: translateX( 6px); }
	100%      { transform: translateX(0); }
}

/* ── Logo block ── */
.login-logo {
	text-align: center;
	margin-bottom: 32px;
}
.logo-icon {
	width: 68px;
	height: 68px;
	margin: 0 auto 14px;
	animation: logoBob 3s ease-in-out infinite;
}
@keyframes logoBob {
	0%, 100% { transform: translateY(0); }
	50%      { transform: translateY(-6px); }
}
.login-title {
	font-family: 'Playfair Display', 'Atkinson', serif;
	font-size: 1.5rem;
	font-weight: 800;
	color: var(--ocean-deep);
	margin: 0 0 4px;
	line-height: 1.25;
}
.login-title em {
	font-style: italic;
	background: linear-gradient(90deg, var(--ocean) 0%, var(--sky) 100%);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-clip: text;
}
.login-subtitle {
	font-size: 0.85rem;
	font-weight: 600;
	color: var(--text-light);
	margin: 0;
	letter-spacing: 0.06em;
	text-transform: uppercase;
}

/* ── Form fields ── */
.login-form {
	display: flex;
	flex-direction: column;
	gap: 18px;
}
.field-group {
	display: flex;
	flex-direction: column;
	gap: 6px;
}
.field-group label {
	font-size: 0.82rem;
	font-weight: 700;
	color: var(--text-mid);
	letter-spacing: 0.03em;
}
.input-wrap {
	position: relative;
	display: flex;
	align-items: center;
}
.input-icon {
	position: absolute;
	left: 14px;
	width: 18px;
	height: 18px;
	color: var(--text-light);
	pointer-events: none;
	transition: color 0.2s;
}
.input-wrap:focus-within .input-icon {
	color: var(--ocean);
}
.input-wrap input {
	width: 100%;
	padding: 12px 44px 12px 42px;
	border: 2px solid var(--mist);
	border-radius: var(--radius-sm);
	font-size: 0.95rem;
	font-family: inherit;
	color: var(--text-dark);
	background: var(--off-white);
	transition: border-color 0.25s, box-shadow 0.25s, background 0.25s;
	outline: none;
	box-sizing: border-box;
}
.input-wrap input::placeholder {
	color: var(--text-light);
	font-weight: 400;
}
.input-wrap input:focus {
	border-color: var(--ocean);
	background: #fff;
	box-shadow: 0 0 0 4px rgba(0, 119, 182, 0.12);
}

/* toggle password eye */
.toggle-pw {
	position: absolute;
	right: 12px;
	background: none;
	border: none;
	cursor: pointer;
	padding: 4px;
	color: var(--text-light);
	display: flex;
	align-items: center;
	transition: color 0.2s;
}
.toggle-pw:hover { color: var(--ocean); }
.toggle-pw svg   { width: 18px; height: 18px; }

/* ── Error message ── */
.error-msg {
	min-height: 20px;
	font-size: 0.83rem;
	font-weight: 600;
	color: #d62828;
	text-align: center;
	transition: opacity 0.2s;
}

/* ── Submit button ── */
.btn-login {
	position: relative;
	width: 100%;
	padding: 14px;
	background: linear-gradient(135deg, var(--ocean) 0%, var(--sky) 100%);
	color: #fff;
	font-size: 1rem;
	font-weight: 800;
	font-family: inherit;
	border: none;
	border-radius: var(--radius-sm);
	cursor: pointer;
	overflow: hidden;
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 8px;
	transition: transform 0.18s, box-shadow 0.18s, background 0.3s;
	box-shadow: 0 4px 20px rgba(0,119,182,0.35);
	margin-top: 4px;
}
.btn-login::before {
	content: '';
	position: absolute;
	inset: 0;
	background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(255,255,255,0) 60%);
	opacity: 0;
	transition: opacity 0.25s;
}
.btn-login:hover:not(:disabled)::before { opacity: 1; }
.btn-login:hover:not(:disabled) {
	transform: translateY(-2px);
	box-shadow: 0 8px 28px rgba(0,119,182,0.45);
}
.btn-login:active:not(:disabled) {
	transform: translateY(0);
}
.btn-login:disabled { opacity: 0.8; cursor: not-allowed; }

/* spinner */
.btn-spinner {
	display: none;
	width: 18px;
	height: 18px;
	border: 2px solid rgba(255,255,255,0.35);
	border-top-color: #fff;
	border-radius: 50%;
}
.btn-login.loading .btn-spinner {
	display: block;
	animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.btn-login.success {
	background: linear-gradient(135deg, #2a9d8f 0%, #57cc99 100%);
}

/* ── Footer note ── */
.login-note {
	text-align: center;
	font-size: 0.75rem;
	color: var(--text-light);
	margin: 22px 0 0;
	font-weight: 600;
}

/* ── Responsive ── */
@media (max-width: 480px) {
	.login-card {
		padding: 32px 22px 28px;
	}
}
</style>
