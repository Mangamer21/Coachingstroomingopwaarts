---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="nl">
	<head>
		<BaseHead
			title="Over mij – Gian Luca Bosmans"
			description="Leer Gian Luca Bosmans kennen: gediplomeerd zwemleerkracht. Ontdek zijn verhaal, aanpak en passie voor zwemmen."
		/>
	</head>
	<body>
		<Header />

		<!-- Page header -->
		<section class="page-header">
			<div class="container">
				<span class="section-label">Wie ben ik?</span>
				<h1>Over mij</h1>
				<p>Passie voor water, geduld voor mensen.</p>
			</div>
			<div class="wave-bottom">
				<svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M0,30 C480,60 960,0 1440,30 L1440,60 L0,60 Z" fill="white"/>
				</svg>
			</div>
		</section>

		<main>
			<!-- Intro section with standing photo -->
			<section class="section intro-section">
				<div class="container">
					<div class="intro-grid">
						<div class="intro-photo-col">
							<div class="photo-frame">
								<img
									src="/photo-luca-standing.png"
									alt="Gian Luca Bosmans – zwemleerkracht"
									class="portrait-photo"
									width="420"
									height="520"
								/>
								<div class="photo-accent"></div>
							</div>
						</div>
						<div class="intro-text">
							<h2>Hallo, ik ben<br/><strong class="highlight">Gian Luca Bosmans</strong></h2>
							<div class="intro-tag">
								<span>🏊 Gediplomeerd zwemleerkracht</span>
							</div>
							<p>
								Zwemmen is mijn roeping. Al van jongs af aan ben ik gefascineerd door het
								water – de vrijheid die je ervaart, de kracht van elke slag, de kalmte onder
								het wateroppervlak. Die liefde voor het water wil ik delen met iedereen die
								ik begeleid.
							</p>
							<p>
								Na mijn opleiding tot gediplomeerd zwemleerkracht begon ik met lesgeven. Sindsdien heb ik honderden kinderen en volwassenen
								geholpen om te zwemmen, angst te overwinnen en zichzelf te overtreffen.
							</p>
							<p>
								<strong>"Stroomingopwaarts"</strong> is niet alleen de naam van mijn coachingspraktijk –
								het is ook mijn filosofie. Elke leerling gaat vooruit, op zijn eigen tempo,
								in zijn eigen richting. Mijn job is jou te begeleiden en te motiveren tot je
								er bent.
							</p>
						</div>
					</div>
				</div>
			</section>

			<!-- Teaching photo + values -->
			<section class="section teaching-section section-alt">
				<div class="container">
					<div class="teaching-grid">
						<div class="teaching-text">
							<span class="section-label" style="text-align:left">In de praktijk</span>
							<h2>Hoe ik lesgeef</h2>
							<p>
								Mijn lessen zijn altijd warm, positief en opgebouwd rond jouw behoeften.
								Of je nu voor het eerst het water in stapt of je slagen wil verfijnen –
								ik pas mijn aanpak volledig aan.
							</p>
							<div class="values-list">
								<div class="value-item">
									<div class="value-icon">🎯</div>
									<div>
										<strong>Persoonlijke aanpak</strong>
										<p>Elk leerplan is uniek. Ik begin altijd met een kennismakingsgesprek om jouw doelen en niveau te begrijpen.</p>
									</div>
								</div>
								<div class="value-item">
									<div class="value-icon">🛡️</div>
									<div>
										<strong>Veiligheid eerst</strong>
										<p>Ik ben gecertificeerd in EHBO en reanimatie. Veiligheid is de basis van elke les.</p>
									</div>
								</div>
								<div class="value-item">
									<div class="value-icon">😄</div>
									<div>
										<strong>Plezier centraal</strong>
										<p>Leren gaat het best als het leuk is. Mijn lessen zijn dynamisch, gevarieerd en positief.</p>
									</div>
								</div>
								<div class="value-item">
									<div class="value-icon">💪</div>
									<div>
										<strong>Geduld & vertrouwen</strong>
										<p>Geen haast. Ik geloof in elk van mijn leerlingen en vier elk succes mee – hoe klein ook.</p>
									</div>
								</div>
							</div>
						</div>
						<div class="teaching-photo-col">
							<div class="teaching-photo-frame">
								<img
									src="/photo-luca-teaching.png"
									alt="Gian Luca geeft zwemles"
									class="teaching-photo"
									width="480"
									height="560"
									loading="lazy"
								/>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Credentials / Timeline -->
			<section class="section credentials-section">
				<div class="container">
					<span class="section-label">Achtergrond</span>
					<h2 class="section-title">Opleiding & ervaring</h2>
					<div class="timeline">
						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<span class="timeline-year">Vandaag</span>
								<h4>Zelfstandig zwemcoach</h4>
								<p>Coaching Stroomingopwaarts – privélessen en techniektraining voor alle leeftijden.</p>
							</div>
						</div>
						<div class="timeline-item">
							<div class="timeline-dot"></div>
							<div class="timeline-content">
								<span class="timeline-year">Certificaten</span>
								<h4>Gediplomeerd zwemleerkracht en Redder</h4>
								<p>Erkende opleiding, gecertificeerd in EHBO en reanimatie, voortdurende bijscholing.</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="cta-banner">
				<div class="container">
					<div class="cta-inner">
						<div class="cta-text">
							<h2>Wil je meer weten?</h2>
							<p>Plan een gratis kennismakingsgesprek. Geen verplichtingen, gewoon even kennismaken.</p>
						</div>
						<div class="cta-actions">
							<a href="/contact" class="btn btn-primary">Contact opnemen</a>
							<a href="/diensten" class="btn btn-outline">Mijn diensten</a>
						</div>
					</div>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	/* Page header */
	.page-header {
		background: linear-gradient(160deg, var(--ocean-deep), var(--ocean));
		color: var(--white);
		padding: 4rem 0 0;
		position: relative;
		text-align: center;
	}
	.page-header .section-label { color: var(--aqua); }
	.page-header h1 { color: var(--white); margin-bottom: 0.5rem; }
	.page-header p { color: rgba(255,255,255,0.8); margin: 0 0 3rem; }
	.wave-bottom { line-height: 0; overflow: hidden; }
	.wave-bottom svg { display: block; width: 100%; }

	/* Intro */
	.intro-grid {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 4rem;
		align-items: start;
	}
	.photo-frame {
		position: relative;
		flex-shrink: 0;
	}
	.portrait-photo {
		width: 360px;
		height: 460px;
		object-fit: cover;
		object-position: top center;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-lg);
		display: block;
		position: relative;
		z-index: 1;
	}
	.photo-accent {
		position: absolute;
		top: 1.5rem;
		left: -1.5rem;
		width: 100%;
		height: 100%;
		border-radius: var(--radius-lg);
		background: linear-gradient(135deg, var(--foam), var(--aqua));
		z-index: 0;
	}
	.intro-text h2 {
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		margin-bottom: 0.75rem;
	}
	.highlight { color: var(--ocean); }
	.intro-tag {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: var(--mist);
		color: var(--ocean);
		padding: 0.4em 1.2em;
		border-radius: 50px;
		font-size: 0.9rem;
		font-weight: 700;
		margin-bottom: 1.5rem;
	}
	.intro-text p { color: var(--text-mid); }

	/* Teaching section */
	.teaching-grid {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 4rem;
		align-items: start;
	}
	.teaching-photo-col {
		flex-shrink: 0;
	}
	.teaching-photo-frame {
		position: relative;
	}
	.teaching-photo {
		width: 420px;
		height: 520px;
		object-fit: contain;
		object-position: center;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-lg);
		display: block;
		background: var(--mist);
	}
	.values-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-top: 1.5rem;
	}
	.value-item {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
	}
	.value-icon {
		font-size: 1.8rem;
		flex-shrink: 0;
		margin-top: 0.1rem;
	}
	.value-item strong {
		display: block;
		font-size: 1.05rem;
		color: var(--ocean-deep);
		margin-bottom: 0.25rem;
	}
	.value-item p {
		font-size: 0.92rem;
		color: var(--text-mid);
		margin: 0;
	}

	/* Timeline */
	.credentials-section { background: var(--white); }
	.timeline {
		max-width: 700px;
		margin: 2.5rem auto 0;
		display: flex;
		flex-direction: column;
		gap: 0;
		position: relative;
	}
	.timeline::before {
		content: '';
		position: absolute;
		left: 20px;
		top: 0;
		bottom: 0;
		width: 2px;
		background: linear-gradient(to bottom, var(--sky), var(--foam));
	}
	.timeline-item {
		display: flex;
		gap: 1.5rem;
		padding-bottom: 2rem;
		position: relative;
	}
	.timeline-dot {
		width: 42px;
		height: 42px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--ocean-mid), var(--sky));
		flex-shrink: 0;
		border: 3px solid var(--white);
		box-shadow: 0 2px 12px rgba(0,180,216,0.35);
		position: relative;
		z-index: 1;
	}
	.timeline-content {
		padding-top: 0.5rem;
	}
	.timeline-year {
		display: inline-block;
		font-size: 0.8rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--sky);
		margin-bottom: 0.25rem;
	}
	.timeline-content h4 {
		font-size: 1.1rem;
		color: var(--ocean-deep);
		margin-bottom: 0.3rem;
	}
	.timeline-content p {
		font-size: 0.95rem;
		color: var(--text-mid);
		margin: 0;
	}

	/* CTA Banner */
	.cta-banner {
		background: linear-gradient(135deg, var(--ocean-deep) 0%, var(--ocean) 100%);
		padding: 4rem 0;
	}
	.cta-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		flex-wrap: wrap;
	}
	.cta-text h2 { color: var(--white); margin-bottom: 0.5rem; }
	.cta-text p { color: rgba(255,255,255,0.8); margin: 0; max-width: 480px; }
	.cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

	/* Responsive */
	@media (max-width: 900px) {
		.intro-grid,
		.teaching-grid {
			grid-template-columns: 1fr;
		}
		.teaching-grid .teaching-photo-col { order: -1; }
		.portrait-photo,
		.teaching-photo {
			width: 100%;
			height: 360px;
		}
		.photo-accent { display: none; }
	}
	@media (max-width: 600px) {
		.cta-inner { flex-direction: column; text-align: center; }
		.cta-actions { justify-content: center; }
	}
</style>
